# Repository operation env.
# Used by Python scripts, Databricks/dbt, and Supabase read-model syncs.
# Next.js site runtime env belongs in apps/site/.env.example.

GARMIN_EMAIL=
GARMIN_PASSWORD=

GARMIN_FIT_S3_BUCKET=
GARMIN_FIT_S3_PREFIX=garmin/fit
GARMIN_HEALTH_S3_BUCKET=
GARMIN_HEALTH_S3_PREFIX=garmin/health/daily

# Hetzner Object Storage (S3-compatible) credentials.
# Generate access keys at: https://console.hetzner.com/projects -> Security -> S3 Credentials
# Available locations: fsn1 (Falkenstein), nbg1 (Nuremberg), hel1 (Helsinki)
OBJECT_STORAGE_ENDPOINT_URL=https://nbg1.your-objectstorage.com
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=nbg1

# https://dbc-<YOUR_HOST_ID>.cloud.databricks.com/settings/user/developer/access-tokens
DATABRICKS_HOST=dbc-<YOUR_HOST_ID>.cloud.databricks.com
DATABRICKS_TOKEN=<YOUR_DATABRICKS_TOKEN>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<YOUR_WAREHOUSE_ID>

DATABRICKS_CATALOG=running_signals
DATABRICKS_BRONZE_SCHEMA=bronze
DATABRICKS_SILVER_SCHEMA=silver
DATABRICKS_GOLD_SCHEMA=gold

# Optional for hosted Supabase read-model syncs. Local sync defaults to
# the Supabase CLI database at postgresql://postgres:postgres@127.0.0.1:54322/postgres.
SUPABASE_DB_URL=
